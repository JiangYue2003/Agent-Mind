# EchoMind 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ── 应用 ──────────────────────────────────────────────────────────────────────
APP_NAME=EchoMind
APP_ENV=production
LOG_LEVEL=INFO

# ── Agent Skills ─────────────────────────────────────────────────────────────
# 管理接口需要此令牌。development 默认自动发布合法上传；production 默认需要显式发布。
SKILL_ADMIN_TOKEN=change_skill_admin_token
# SKILL_REVIEW_REQUIRED=true
# SKILL_RELOAD_INTERVAL_SECONDS=1
# SKILL_CATALOG_DIR=./skills/catalog
# SKILL_DATA_DIR=./data/skills

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 可选：覆盖为兼容 Anthropic 协议的第三方 API（如 DeepSeek）
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 可选：覆盖模型名称（默认 claude-3-5-sonnet-20241022）
# 使用 DeepSeek 时设为 deepseek-chat
# ANTHROPIC_MODEL=deepseek-chat

# ── LLM 调用韧性 ─────────────────────────────────────────────────────────────
# 单次 LLM 调用的总预算包含所有尝试与退避等待；只重试超时、网络、限流和 5xx。
LLM_TIMEOUT_MS=12000
LLM_RETRY_LIMIT=2
LLM_RETRY_BASE_DELAY_MS=200
LLM_RETRY_MAX_DELAY_MS=2000

# ── RAGAS embedding 评测 ─────────────────────────────────────────────────────
# 仅由 ragas-eval 容器使用，必须配置为 OpenAI-compatible embedding endpoint。
# EVAL_EMBEDDING_API_KEY=your_embedding_api_key_here
# EVAL_EMBEDDING_BASE_URL=https://your-embedding-endpoint/compatible-mode/v1
EVAL_EMBEDDING_MODEL=text-embedding-v4

# ── 阿里云百炼 Embedding ─────────────────────────────────────────────────────
# 使用已轮换的工作空间 API Key；不要将真实密钥提交到 Git。
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_HTTP_BASE_URL=https://your-workspace-host/api/v1
DASHSCOPE_WORKSPACE=ws-your_workspace
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=echomind123

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIRECTORY=./data/chroma

# ── 监控 ──────────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9091
ANOMALY_DETECTION_THRESHOLD=2.0

# ── 评测 ──────────────────────────────────────────────────────────────────────
EVAL_BASELINE_PATH=./data/eval/baseline.json
EVAL_WORKFLOW_DATASET=/app/evaluation/datasets/customer_service_workflow_v1.jsonl
# 检索评测固定为“召回 20 条，再由本地 GPU reranker 取最终 Top-5”；无真实重排时直接失败。
EVAL_TOP_K=5
EVAL_RECALL_K=20
EVAL_RETRIEVAL_GOLD_PATH=evaluation/datasets/customer_service_retrieval_gold_v2.json
EVAL_REQUIRE_RERANK=true
EVAL_REQUIRED_RERANK_PROVIDER=tei
# 同时进行的 RAGAS 度量任务数；提高该值会更快，也更容易撞到评判模型限流。
EVAL_MAX_CONCURRENCY=3

# ── 知识库重排 ──────────────────────────────────────────────────────────────
# Docker Desktop 默认访问宿主机的 local_reranker 服务；协议与 TEI /rerank 兼容。
RERANK_PROVIDER=tei
RERANK_URL=http://host.docker.internal:18080/rerank
# 保证候选集大于最终 Top-K，供 GPU reranker 做真实排序。
RAG_HYBRID_RECALL_K=20
RAG_RERANK_CANDIDATE_K=20
RAG_ANSWER_TOP_K=5
RAG_RERANK_TIMEOUT_SECONDS=20
RAG_RERANK_SCORE_THRESHOLD=0.05

# ── 安全 ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production
JWT_SECRET_KEY=change_this_in_production

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── 功能开关 ──────────────────────────────────────────────────────────────────
ENABLE_SWAGGER_UI=true
ENABLE_MONITORING=true
ENABLE_EVALUATION=true
